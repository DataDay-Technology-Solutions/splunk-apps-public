<dashboard version="1.1"
  stylesheet="splunk-innovators-toolkit:css/sit-panel-polish.css,
             splunk-innovators-toolkit:themes/dark-mode-pro.css"
  script="splunk-innovators-toolkit:widgets/real-time-clock.js,
          splunk-innovators-toolkit:widgets/countdown-timer.js,
          splunk-innovators-toolkit:widgets/gauge-speedometer.js,
          splunk-innovators-toolkit:widgets/gauge-liquid-fill.js,
          splunk-innovators-toolkit:widgets/qr-code-generator.js,
          splunk-innovators-toolkit:widgets/weather-widget.js,
          splunk-innovators-toolkit:widgets/team-status-board.js,
          splunk-innovators-toolkit:visualizations/heatmap-calendar.js,
          splunk-innovators-toolkit:visualizations/kanban-board.js,
          splunk-innovators-toolkit:visualizations/org-chart-interactive.js,
          splunk-innovators-toolkit:visualizations/terminal-log-viewer.js,
          splunk-innovators-toolkit:visualizations/timeline-gantt.js,
          splunk-innovators-toolkit:visualizations/animated-svg-network-map.js,
          splunk-innovators-toolkit:visualizations/globe-3d-rotate.js,
          splunk-innovators-toolkit:toggles/dark-light-mode.js,
          splunk-innovators-toolkit:toggles/fullscreen-mode.js,
          splunk-innovators-toolkit:toggles/panel-collapse-accordion.js,
          splunk-innovators-toolkit:animations/panel-entrance-fade.css,
          splunk-innovators-toolkit:animations/hover-glow-border.css"
  hideEdit="true">
  <label>Widget Test Page</label>
  <description>Tests every widget and visualization for Splunk 10.2 compatibility</description>

  <row>
    <panel>
      <title>Clock</title>
      <html><![CDATA[
        <div class="world-clock" data-format="12h" data-timezone="local"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Countdown</title>
      <html><![CDATA[
        <div class="countdown-widget" data-target="2026-12-31T00:00:00" data-label="New Year"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Speedometer</title>
      <html><![CDATA[
        <div class="gauge-speedometer" data-value="72" data-max="100" data-label="CPU"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Liquid Gauge</title>
      <html><![CDATA[
        <div class="gauge-liquid-fill" data-value="65" data-label="Memory"></div>
      ]]></html>
    </panel>
  </row>

  <row>
    <panel>
      <title>QR Code</title>
      <html><![CDATA[
        <div class="qr-inline" data-value="https://splunk.com" data-label="Splunk"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Weather</title>
      <html><![CDATA[
        <div class="weather-widget" data-city="San Francisco" data-condition="sunny" data-temp="72" data-unit="F"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Team Board</title>
      <html><![CDATA[
        <div class="team-board" data-title="On Call" data-layout="grid">
          <div class="team-member" data-name="Alice" data-role="Lead" data-status="online"></div>
          <div class="team-member" data-name="Bob" data-role="Engineer" data-status="busy"></div>
        </div>
      ]]></html>
    </panel>
    <panel>
      <title>Traffic Lights</title>
      <html><![CDATA[
        <div class="sit-traffic-light" data-status="green" data-label="API"></div>
        <div class="sit-traffic-light" data-status="yellow" data-label="DB"></div>
        <div class="sit-traffic-light" data-status="red" data-label="Queue"></div>
      ]]></html>
    </panel>
  </row>

  <row>
    <panel>
      <title>Heatmap Calendar</title>
      <html><![CDATA[
        <div id="heatmap-calendar-test" data-viz="heatmap-calendar" data-color-scheme="green" data-label="Events" style="width:100%;height:200px;"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Kanban Board</title>
      <html><![CDATA[
        <div id="kanban-board-test" data-viz="kanban-board" style="width:100%;min-height:250px;"></div>
      ]]></html>
    </panel>
  </row>

  <row>
    <panel>
      <title>Org Chart</title>
      <html><![CDATA[
        <div id="org-chart-test" data-viz="org-chart" style="width:100%;height:250px;"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Terminal Log</title>
      <html><![CDATA[
        <div id="terminal-log-test" data-viz="terminal-log" data-title="System Logs" data-theme="green" style="width:100%;height:250px;"></div>
      ]]></html>
    </panel>
  </row>

  <row>
    <panel>
      <title>Timeline / Gantt</title>
      <html><![CDATA[
        <div id="timeline-gantt-test" data-viz="timeline-gantt" style="width:100%;height:200px;"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Network Map</title>
      <html><![CDATA[
        <div id="network-map-test" data-viz="network-map" style="width:100%;height:250px;"></div>
      ]]></html>
    </panel>
  </row>

  <row>
    <panel>
      <title>3D Globe</title>
      <html><![CDATA[
        <div id="globe-3d-test" data-viz="globe-3d" data-auto-rotate="true" style="width:100%;height:300px;"></div>
      ]]></html>
    </panel>
    <panel>
      <title>Real Single Value</title>
      <single>
        <search>
          <query>index=_internal | stats count</query>
          <earliest>-1h@h</earliest>
          <latest>now</latest>
        </search>
      </single>
    </panel>
  </row>

</dashboard>
